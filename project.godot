; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pilot"
run/main_scene="res://ui/lobby.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(1, 1, 1, 1)
boot_splash/stretch_mode=3
boot_splash/image="uid://cktbam0vo41cn"
config/icon="uid://dpd0bc56mvhj1"
boot_splash/minimum_display_time=500

[audio]

buses/default_bus_layout="uid://dx0gjxrr1auh0"

[autoload]

GameState="*res://autoload/game_state.gd"
InputHelper="*res://autoload/input_helper.gd"
AudioManager="*uid://cch00ygm1pukj"
ItemRegistry="*res://autoload/item_registry.gd"
ItemTooltip="*res://autoload/item_tooltip.gd"
NetworkManager="*res://autoload/network_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/godotsteam/plugin.cfg")

[global]

Master=false
SFX.custom=false
SFX=""

